{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "export PATH=\"$HOME/.cargo/bin:$PATH\" && cargo install --locked wasm-bindgen-cli --version 0.2.117",
  "buildCommand": "export PATH=\"$HOME/.cargo/bin:$PATH\" && bash scripts/build-web.sh",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "require-corp"
        }
      ]
    }
  ]
}
